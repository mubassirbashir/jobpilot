# ─────────────────────────────────────────────
# JobPilot AI — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Database (MongoDB Atlas or local)
MONGODB_URI=mongodb://localhost:27017/jobpilot

# Redis (for job queues)
REDIS_URL=redis://localhost:6379

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LinkedIn OAuth 2.0 (from LinkedIn Developer Portal)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/auth/linkedin/callback

# Encryption (for storing LinkedIn session cookies securely)
ENCRYPTION_KEY=your_32_char_encryption_key_here_x

# Optional: Email for follow-up automation
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Rate limits
MAX_DAILY_APPLICATIONS=20
MAX_CONCURRENT_AGENTS=3
